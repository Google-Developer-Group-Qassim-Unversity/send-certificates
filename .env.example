# Secrets are managed in Infisical under the path /emails-backend
# See docs/ENVIRONMENT_VARIABLES.md for setup instructions
#
# Gmail App Passwords
APP_PASSWORD_KERNELTICS=your_password_here
APP_PASSWORD_GDG_QASSIM=your_password_here

# Cloudflare R2
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=your_bucket_name
R2_PUBLIC_URL=https://your-public-url.dev
